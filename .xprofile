#setxkbmap -layout us,ara -option caps:super
TOUCHPAD=$(xinput list --name-only | grep -i touchpad)
xinput set-prop "$TOUCHPAD" "libinput Tapping Enabled" 0
export XCURSOR_THEME=LyraQ-cursors
export TERMINAL="alacritty"
export GDK_SCALE=1
export GDK_DPI_SCALE=1
export EDITOR="vim"
export VISUAL="vim"
export MANPAGER="nvim +Man!"
export PAGER="bat --paging=always --style="changes" --wrap=auto"
export SYSTEMD_LESS=
export SYSTEMD_PAGER=
export SYSTEMD_PAGERSECURE=0
export FZF_DEFAULT_OPTS="--bind tab:up,shift-tab:down --color=fg:#f8f8f2,bg:#282a36,hl:#bd93f9 --color=fg+:#f8f8f2,bg+:#44475a,hl+:#bd93f9 --color=info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6 --color=marker:#ff79c6,spinner:#ffb86c,header:#6272a4"
export GOPATH="$HOME/go"
export GTK_IM_MODULE=fcitx
export QT_IM_MODULE=fcitx
export XMODIFIERS=@im=fcitx
export XDG_CACHE_HOME="$HOME/.local/cache"
export XDG_DATA_HOME="$HOME/.local/share"
export XDG_CONFIG_HOME="$HOME/.config"
export XDG_SATE_HOME="$HOME/.local/state"
