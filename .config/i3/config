# This file has been auto-generated by i3-config-wizard(1).
set $mod Mod4
set $zscripts /home/zaater/.config/scripts
#font pango:Fredoka Condensed, Medium Condensed 12
font pango:Fredoka Medium 12
#for the mouse theme
exec_always --no-startup-id xrdb -merge ~/.Xresources
#exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id fcitx5 -dr
#exec_always --no-startup-id blueman-applet
exec --no-startup-id exec picom -b 
exec --no-startup-id feh --bg-fill /usr/share/backgrounds/Nighthawks_by_Edward_Hopper_1942.jpg
# battery warner
exec --no-startup-id $zscripts/battery-warner.sh
#power manager
bindsym --release XF86PowerOff exec $zscripts/power-menu.sh 
exec --no-startup-id xset s 600 500
exec --no-startup-id xss-lock -n /usr/share/doc/xss-lock/dim-screen.sh -- i3lock -n
# Refresh i3status
set $refresh_i3status killall -SIGUSR1 i3status
# Arabic
bindsym $mod+F3 exec --no-startup-id $zscripts/kblayout.sh
# Ask
bindsym $mod+slash exec --no-startup-id alacritty --class full-term -e bash $zscripts/wikiman.sh
# Volume
bindsym XF86AudioRaiseVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% && $refresh_i3status
bindsym XF86AudioLowerVolume exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% && $refresh_i3status
bindsym XF86AudioMute exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle && $refresh_i3status
bindsym XF86AudioMicMute exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle && $refresh_i3status
# Use Mouse+$mod to drag floating windows to their wanted position
floating_modifier $mod
#screenshot
bindsym F11 exec --no-startup-id flameshot gui
#&& pkill flameshot
#drow
bindsym $mod+F9 exec --no-startup-id gromit-mpx 
#left-clicking anywhere into the window while holding the floating modifier.
tiling_drag modifier titlebar
# start a terminal
bindsym $mod+Return exec --no-startup-id alacritty
# kill focused window
bindsym $mod+Shift+q kill
bindsym $mod+Delete kill
# browser shortcut
bindsym $mod+b exec --no-startup-id firefox
# change focus
bindsym $mod+h focus left
bindsym $mod+k focus up
bindsym $mod+j focus down 
bindsym $mod+l focus right
# alternatively, you can use the cursor keys:
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right
# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+k move up
bindsym $mod+Shift+j move down 
bindsym $mod+Shift+l move right
# alternatively, you can use the cursor keys:
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right
# split in vertical orientation
bindsym $mod+v split v
# enter fullscreen mode for the focused container
bindsym $mod+f fullscreen toggle
# change container layout (stacked, tabbed, toggle split)
bindsym $mod+s layout stacking
bindsym $mod+w layout tabbed
bindsym $mod+e layout toggle split
# toggle tiling / floating
bindsym Shift+space floating toggle
#note keeper
bindsym $mod+n exec --no-startup-id $zscripts/notes.sh
#launcher
bindsym $mod+space exec --no-startup-id rofi -show drun
bindsym $mod+g exec --no-startup-id rofi -show run
# focus the parent container
bindsym $mod+a focus parent
# focus the child container
bindsym $mod+d focus child
# We use variables to avoid repeating the names in multiple places.
set $ws1 "1: "
set $ws2 "2:󰈹 "
set $ws3 "3: "
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8:󰍨 "
set $ws9 "9:󰔠 "
set $ws10 "10:󰎌"
# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+u workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+i workspace number $ws9
bindsym $mod+0 workspace number $ws10
bindsym $mod+o workspace number $ws10
# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+u move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+i move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10
bindsym $mod+Shift+o move container to workspace number $ws10
# scratchpad
#bindsym $mod+Shift+m mark "sp1", move scratchpad
#bindsym $mod+m [con_mark="sp1"] scratchpad show
# Start terminal and send it to scratchpad
exec --no-startup-id alacritty --class=scratchpad-term
for_window [class="scratchpad-term"] move scratchpad
bindsym $mod+m scratchpad show
bindsym $mod+Shift+m move scratchpad

# thorium browser
assign [class="Thorium-browser" instance="thorium-browser"] $ws2
# google chrome browser
assign [class="Google-chrome" instance="google-chrome"] $ws2
# firefox browser
assign [class="firefox"] $ws2
# Telegram
assign [class="TelegramDesktop"] $ws8
# Instagram
assign [class="Google-chrome" instance="crx_akpamiohjfcnimfljfndmaldlcfphjmp"] $ws3
# Whatsapp
assign [class="Thorium-browser" instance="crx_hnpfjngllnobngcgfapefoaidbinmjnm"] $ws3
# Youtube
assign [class="Google-chrome" instance="crx_cinhimbnkkaeohfgghhklpknlkffjgod"] $ws10
assign [class="firefox" title=".*YouTube.*"] $ws10
# reload the configuration file
bindsym $mod+Shift+c restart
# restart i3 inplace (preserves your layout/session, can be used to upgrade i3)
bindsym $mod+r reload
# exit i3 (logs you out of your X session)
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
# resize window (you can also use the mouse for that)
mode "resize" {
	bindsym h resize grow width 10 px or 10 ppt
	bindsym k resize grow height 10 px or 10 ppt
	bindsym j resize shrink height 10 px or 10 ppt
	bindsym l resize shrink width 10 px or 10 ppt
	bindsym Left resize shrink width 10 px or 10 ppt
	bindsym Down resize grow height 10 px or 10 ppt
	bindsym Up resize shrink height 10 px or 10 ppt
	bindsym Right resize grow width 10 px or 10 ppt
	bindsym Return mode "default"
	bindsym Escape mode "default"
	bindsym $mod+r mode "default"
}
bindsym $mod+Shift+r mode "resize"
# copy
bindsym $mod+y exec --no-startup-id $zscripts/cliphist.sh add
bindsym $mod+p exec --no-startup-id $zscripts/cliphist.sh sel
bindsym $mod+Shift+y exec --no-startup-id mpv --autofit=60%  $(xclip -o)
# bar
set $bg #2f343f7f
bar {
	i3bar_command i3bar --transparency
	status_command i3status # i3status-title-on-bar --fixed-width 59
	tray_padding 5
	font pango:JetBrainsMono NF Bold 10
	position top
	bindsym button5 nil
	bindsym button4 nil
	colors {
		background $bg
		statusline #f8f8f2
		separator $bg
		focused_workspace  #fffffff0 #2f343ff0 #ffffff
		inactive_workspace $bg $bg #6272a4
		urgent_workspace   $bg #2f343ff0 #ff5555
	}
}
# class                 border  bground text    indicator child_border
client.focused          #ba55d3 #ba55d3 #ffffff #bd93f9   #ba55d3
client.focused_inactive #44475A #44475A #F8F8F2 #44475A   #44475A
client.unfocused        #282A36 #282A36 #BFBFBF #282A36   #585A56
client.urgent           #44475A #FF5555 #F8F8F2 #FF5555   #FF5555
client.placeholder      #282A36 #282A36 #F8F8F2 #282A36   #282A36
for_window [class=".*"] border pixel 2
focus_follows_mouse no
for_window [class=".*notifyd.*"] border none
for_window [class="Dunst"] border none
for_window [class="zenity"] border none
for_window [class="Nsxiv"] floating enable
for_window [class="mpv"] floating enable
for_window [class="float-term"] floating enable
for_window [class="full-term"] fullscreen enable
for_window [class="Blueman-manager"] floating enable

popup_during_fullscreen  all
